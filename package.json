{
  "name": "mdvu",
  "version": "1.0.1",
  "description": "simple drag-n-drop markdown viewer with syntax highlighting",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "electron:preview": "cross-env BUILD_TARGET=electron astro build --outDir dist-electron && electron .",
    "electron:dist": "cross-env BUILD_TARGET=electron astro build --outDir dist-electron && electron-builder"
  },
  "dependencies": {
    "astro": "^7.0.3",
    "highlight.js": "^11.9.0",
    "marked": "^9.1.6",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@astrojs/svelte": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "ca.loba-lo.mdvu",
    "productName": "mdvu",
    "directories": {
      "buildResources": "public",
      "output": "release/${version}"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "linux": {
      "target": "AppImage"
    },
    "publish": {
      "provider": "github"
    }
  }
}
